# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase
# (Project Settings > API no painel do Supabase)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# ID do Pixel do Meta (Gerenciador de Eventos > Fontes de Dados > seu pixel)
VITE_FB_PIXEL_ID=SEU_PIXEL_ID_AQUI
